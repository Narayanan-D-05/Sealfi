{
  "name": "sealfi-contracts",
  "version": "2.0.0",
  "description": "SealFi - Confidential DAO Governance Contracts (fhevm v0.11.x stack)",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test test/SealGovernor.test.ts",
    "test:sepolia": "npx hardhat test test/SealGovernor.test.ts --network sepolia",
    "deploy": "npx hardhat run scripts/deploy.ts --network sepolia",
    "seed": "npx hardhat run scripts/seed.ts --network sepolia",
    "clean": "npx hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.3.0",
    "@types/node": "^20.12.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.15",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@fhevm/hardhat-plugin": "0.4.2",
    "@fhevm/solidity": "0.11.1"
  }
}
